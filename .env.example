# Polish Cash — Environment Variables
# Copy this file to .env.local and fill in the values.

# Path to the SQLite database file (defaults to ./polish-cash.db)
# DATABASE_URL=./polish-cash.db

# GitHub webhook secret — used to verify incoming webhook payloads
# Generate one: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Linear API key — used to fetch ticket details (team, title, description)
# Get one at: https://linear.app/settings/api
LINEAR_API_KEY=
